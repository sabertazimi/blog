{
  "name": "@sabertazimi/blog",
  "type": "module",
  "version": "5.4.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "description": "A blog system based on React and Next",
  "author": "sabertazimi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sabertazimi/blog"
  },
  "bugs": {
    "url": "https://github.com/sabertazimi/blog/issues"
  },
  "keywords": [
    "blog",
    "next",
    "react",
    "mdx",
    "tailwindcss",
    "typescript",
    "shadcn",
    "starter"
  ],
  "browserslist": "last 2 versions",
  "scripts": {
    "dev": "next dev",
    "clone": "git clone https://$VERCEL_GIT_PROVIDER.com/$VERCEL_GIT_REPO_OWNER/$VERCEL_GIT_REPO_SLUG && rm -fr .git && cp -fr $VERCEL_GIT_REPO_SLUG/.git . && rm -fr $VERCEL_GIT_REPO_SLUG",
    "build": "next build",
    "serve": "next start",
    "lint": "pnpm lint:style && pnpm lint:type-check",
    "lint:style": "eslint . && stylelint ./src/**/*.css",
    "lint:type-check": "tsc --noEmit",
    "lint:fix": "eslint . --fix && stylelint ./src/**/*.css --fix",
    "test": "vitest",
    "test:all": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "changeset": "commit-and-tag-version --dry-run -s",
    "release": "commit-and-tag-version -s"
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@giscus/react": "^3.1.0",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "katex": "^0.17.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.0",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "parse-numeric-range": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@dg-scripts/eslint-config": "^6.2.0",
    "@dg-scripts/stylelint-config": "^6.2.0",
    "@next/eslint-plugin-next": "^16.2.9",
    "@octokit/rest": "^22.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/unist": "^3.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.5.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-mdx-code-props": "^3.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github": "^12.0.0",
    "remark-math": "^6.0.0",
    "stylelint": "^17.13.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.9"
  }
}
